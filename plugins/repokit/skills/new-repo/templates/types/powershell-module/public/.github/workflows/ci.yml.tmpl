name: CI

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]
  workflow_dispatch:

jobs:
  test:
    name: PSScriptAnalyzer + Pester
    runs-on: ubuntu-latest
    defaults:
      run:
        shell: pwsh
    steps:
      - uses: actions/checkout@v4

      - name: Install PSScriptAnalyzer and Pester
        run: |
          Set-PSRepository PSGallery -InstallationPolicy Trusted
          Install-Module PSScriptAnalyzer -Force -Scope CurrentUser
          Install-Module Pester -Force -Scope CurrentUser

      - name: Lint (PSScriptAnalyzer — fail on Error severity)
        run: |
          $issues = Invoke-ScriptAnalyzer -Path . -Recurse -Severity Error
          if ($issues) {
            $issues | Format-Table -AutoSize
            throw "PSScriptAnalyzer found $($issues.Count) error-severity issue(s)."
          }

      - name: Test (Pester)
        run: Invoke-Pester -Path ./Tests -CI
