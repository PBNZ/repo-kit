# {{name}} — Docker Compose stack.
# Config (this file, .env.example, service config files) is committed. Persistent
# data uses named volumes, which live OUTSIDE the repo. Secrets go in .env
# (gitignored; copy .env.example). Validate the file with: docker compose config -q
services:
  app:
    image: example/app:latest
    restart: unless-stopped
    ports:
      - "${APP_PORT:-8080}:8080"   # ${VAR} is interpolated from the auto-loaded .env
    networks: [stack]
    # Commit config and mount it read-only:
    # volumes:
    #   - ./config/app.conf:/etc/app/app.conf:ro

  db:
    image: postgres:16
    restart: unless-stopped
    environment:
      POSTGRES_PASSWORD: ${DB_PASSWORD:?set DB_PASSWORD in .env}
    volumes:
      - db-data:/var/lib/postgresql/data   # named volume -> data lives outside the repo
    networks: [stack]

  # Build a service from a local Dockerfile instead of a prebuilt image:
  # worker:
  #   build: ./services/worker
  #   networks: [stack]

volumes:
  db-data:

networks:
  stack:
